# api/.env.example
# Copy to .env and edit paths for your machine
# When running from the project root: paths below are correct as-is

# Paths to the trained model and ML-100K data
MODEL_PATH=models/hybrid_model.pt
DATA_DIR=data/ml-100k

# Server settings
HOST=0.0.0.0
PORT=8000

# Recommendation defaults
TOP_N=10
POPULAR_MOVIES_COUNT=20

# CORS: which origins can call this API directly
# Spring Boot is on 8080; React dev on 3000; Vite dev on 5173
CORS_ORIGINS=http://localhost:8080,http://localhost:3000,http://localhost:5173
